# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# Claude Code runtime state (lock files, caches)
.claude/scheduled_tasks.lock
.claude/cache/
.claude/worktrees/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# B-O-E autobuild artifacts (runtime only — specs & handoffs are tracked)
.yagi-autobuild/checkpoints/
.yagi-autobuild/logs/
.yagi-autobuild/tmp/
.yagi-autobuild/*.log
.yagi-autobuild/**/*.tmp
# Transient codex/telegram prompt dumps (noisy, not useful history)
.yagi-autobuild/_codex_review_*.txt
.yagi-autobuild/_telegram_*.txt
# Codex K-PUX (Product/UX) review artifacts — transient like K-05
.yagi-autobuild/**/_codex_kpux_output.txt
# Phase-level run logs + review outputs (per-Builder transient)
.yagi-autobuild/**/_run.log
.yagi-autobuild/**/_codex_review_output*.txt
.yagi-autobuild/**/_codex_review_prompt*.md
.yagi-autobuild/**/_codex_kpux_prompt*.md
.yagi-autobuild/**/_codex_kpux_output*.txt
# But preserve archived phase artifacts (intentional history under /archive/)
!.yagi-autobuild/archive/**

# Local verification logs (tsc/lint/build outputs at repo root)
.build.log
.lint.log
.tsc.log
# Migration list captures (transient diagnostic outputs)
.migration-list.txt
.migration-list-final.txt
.migration-list-*.txt
# Other ad-hoc diagnostic captures
.bg-check.txt

# Content Collections generated files
.content-collections/

# Supabase CLI local state (cache, linked project info, CLI versions)
# Never commit — these are per-developer machine state.
supabase/.temp/
supabase/.branches/

# Phase 2.8.4 — high-res source originals for brand/sample assets.
# Optimized outputs land directly in public/brand/ and ship to the bundle;
# sources stay on disk for re-export but are never committed.
public/brand/sources/
