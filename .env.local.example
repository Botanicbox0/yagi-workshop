# ============================================================
# YAGI Workshop — Environment Variables Template
# Copy to .env.local and fill in actual values. Never commit .env.local.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (dev: http://localhost:3003)
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# Anthropic (AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (Builder notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Google Calendar / Meet — Phase 1.3
# Setup: docs/google-oauth-setup.md
# Redirect URI: http://localhost:3003/api/auth/google/callback
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ============================================================
# Resend (transactional email) — Phase 1.3+
# ============================================================
RESEND_API_KEY=re_...

# ============================================================
# Popbill (Korean e-tax invoice) — Phase 1.5
#
# Three modes: mock | test | production.
# - mock: returns fake nts_approval_number, never hits 국세청. Default for fresh clones.
# - test: hits 팝빌 test environment. Requires LINK_ID + SECRET_KEY + CORP_NUM filled.
#         issueTaxInvoice() in src/lib/popbill/client.ts is currently NOT_IMPLEMENTED
#         for test+production — real popbill SDK call still needs to be wired.
# - production: hits real 국세청. Vercel production env only — never .env.local.
#
# CORP_NUM = 10-digit 사업자등록번호 of YAGI Workshop (no hyphens).
# Production safety guard in client.ts:9 throws if mode=mock + Vercel production.
# Full flip procedure: .yagi-autobuild/phase-2-0/POPBILL_LIVE_FLIP.md
# ============================================================
POPBILL_MODE=mock
POPBILL_LINK_ID=<your-popbill-link-id>
POPBILL_SECRET_KEY=<your-popbill-secret-key>
POPBILL_CORP_NUM=<your-10-digit-business-registration-number>

# ============================================================
# OpenAI (Codex plugin review) — optional, ChatGPT sub covers this too
# ============================================================
# OPENAI_API_KEY=

# ============================================================
# Image generation provider — Phase 1.4 legacy
# ============================================================
IMAGE_PROVIDER=fal-flux-schnell
# COMFYUI_BASE_URL=http://localhost:8188
# FAL_API_KEY=

# ============================================================
# Builder / B-O-E autobuild config
# Karpathy mode: minimize eval loops (2 is enough).
# ============================================================
AUTOBUILD_MAX_EVAL_LOOPS=2
AUTOBUILD_KILL_SWITCH_NOTIFY=telegram
